{
  "name": "tsgo-ast-root",
  "private": true,
  "type": "module",
  "workspaces": ["npm"],
  "scripts": {
    "build:wasm": "bash scripts/build.sh",
    "build:js": "rolldown -c",
    "build": "bun run build:wasm && bun run build:js",
    "test:release": "bun test scripts/release-lib.test.mjs",
    "release:pr": "node scripts/release-pr.mjs",
    "release": "bun run build && cd npm && npm publish --provenance --access public"
  },
  "devDependencies": {
    "rolldown": "^1.0.0-beta.8",
    "typescript": "^5.9.3"
  }
}
